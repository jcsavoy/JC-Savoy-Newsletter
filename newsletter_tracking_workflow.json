    {
      "parameters": {
        "jsCode": "/* UNIFIED COLLECTOR WITH INCREMENT LOGIC */\nconst query = $node[\"Webhook: Open Tracking\"].json.query || $node[\"Webhook: Click Tracking\"].json.query || $node[\"Webhook: Feedback Tracking\"].json.query || {};\nconst sheetData = $json; // This is the row from Google Sheets\n\nlet type = 'feedback';\nif (query.url) type = 'click';\nelse if (!query.section) type = 'open';\n\nlet col = '';\nif (type === 'click') {\n  col = 'Clicked';\n} else if (type === 'open') {\n  col = 'Opened';\n} else {\n  const section = String(query.section || '').toLowerCase();\n  const vote = String(query.vote || '').toLowerCase();\n\n  if (section === 'joke') {\n    col = (vote === 'up') ? 'Joke: Liked' : 'Joke: Disliked';\n  } else if (section === 'gazette') {\n    col = (vote === 'up') ? 'Gazette: Liked' : 'Gazette: Disliked';\n  } else if (section === 'recipe') {\n    if (vote === 'going') col = 'Recipe: Going to Try';\n    else if (vote === 'liked') col = 'Recipe: Liked';\n    else if (vote === 'disliked') col = 'Recipe: Disliked';\n  }\n}\n\n// MATH: Get the old value and add 1\nconst oldScore = Number(sheetData[col] || 0);\nconst newScore = oldScore + 1;\n\nconst redirectUrl = (type === 'click' && query.url)\n  ? decodeURIComponent(query.url)\n  : 'https://jcsavoy.com/newsletter-april-2026.html';\n\nreturn {\n  \"Subscriber email\": query.email || 'unknown@jcsavoy.com',\n  [col]: newScore, // This maps the dynamic column name to the new score\n  redirectUrl: redirectUrl\n};"
      },
      "id": "scoremaster",
      "name": "Math: Scoremaster",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [650, 350]
    },
