      "id": "lookup-row",
      "name": "Google Sheets: Lookup Row",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        400,
        400
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const query = $node[\"Webhook: Click Tracking\"].json.query || \n              $node[\"Webhook: Open Tracking\"].json.query || \n              $node[\"Webhook: Feedback Tracking\"].json.query || {};\n\nlet type = \"feedback\";\nif (query.url) type = \"click\";\nelse if (!query.section) type = \"open\";\n\nlet col = \"\";\nif (type === \"click\") col = \"Clicked\";\nelse if (type === \"open\") col = \"Opened\";\nelse {\n    const section = String(query.section || \"\").toLowerCase();\n    const vote = String(query.vote || \"\").toLowerCase();\n    if (section === \"joke\") col = (vote === \"up\") ? \"Joke: Liked\" : \"Joke: Disliked\";\n    else if (section === \"gazette\") col = (vote === \"up\") ? \"Gazette: Liked\" : \"Gazette: Disliked\";\n    else if (section === \"recipe\") {\n        if (vote === \"going\") col = \"Recipe: Going to Try\";\n        else if (vote === \"liked\") col = \"Recipe: Liked\";\n        else if (vote === \"disliked\") col = \"Recipe: Disliked\";\n    }\n}\n\nconst output = { ...$json }; // Start with row from Lookup\nif (col) {\n    output[col] = (Number($json[col]) || 0) + 1; // Increment the targeted column\n}\n\noutput.type = type;\noutput.url = query.url || \"\";\noutput.targetEmail = query.email || $json[\"Subscriber email\"];\n\nreturn output;"
      },
      "id": "scoremaster",
      "name": "Math: Scoremaster",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
