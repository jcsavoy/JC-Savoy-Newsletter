{
  "name": "JC Savoy Subscriber Management",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "subscribe",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-subscribe",
      "name": "Webhook: Subscribe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.body.website_url }}",
              "operation": "isEmpty"
            }
          ]
        }
      },
      "id": "if-honeypot",
      "name": "Honeypot Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [200, 0]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "18KYRnngYNcLaCpivRS5dXPm9Ryk7pngfvz5PoEhA44E",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Subscribers",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "manual",
          "value": {
            "Subscriber email": "={{ $json.body.email }}",
            "First Name": "={{ $json.body.first_name }}",
            "Location": "={{ $json.body.location || \"Website\" }}",
            "Date joined": "={{ $now.format(\"yyyy-MM-dd\") }}"
          }
        },
        "options": {}
      },
      "id": "gsheets-subscribe",
      "name": "Google Sheets: Add Subscriber",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [400, -100]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mailerlite-unsubscribe",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-unsubscribe",
      "name": "Webhook: Unsubscribe (MailerLite)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "jsCode": "// MailerLite sends subscriber email at: data.subscriber.email\nconst body = $input.first().json.body;\nconst email = body?.data?.subscriber?.email || body?.email || '';\nif (!email) throw new Error('No email found in webhook payload');\nreturn [{ json: { email } }];"
      },
      "id": "code-extract-email",
      "name": "Extract Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "18KYRnngYNcLaCpivRS5dXPm9Ryk7pngfvz5PoEhA44E",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Subscribers",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "manual",
          "value": {
            "unsubscribed": "={{ $now.format(\"yyyy-MM-dd\") }}"
          }
        },
        "where": {
          "values": [
            {
              "column": "Subscriber email",
              "value": "={{ $json.email }}"
            }
          ]
        },
        "options": {}
      },
      "id": "gsheets-unsubscribe",
      "name": "Google Sheets: Mark Unsubscribed",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-unsubscribe",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [660, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "={{ $node[\"gsheets-subscribe\"].json[\"Subscriber email\"] }}",
        "subject": "Welcome to the JC Savoy Family! (And your free book 📖)",
        "text": "=Hi {{ $node[\"gsheets-subscribe\"].json[\"First Name\"] }},\n\nSo glad you're here! As promised, here is your free copy of [Book Title] via BookFunnel: [INSERT_BOOKFUNNEL_LINK_HERE]\n\nHappy reading!\n\nJC Savoy",
        "appendAttribution": false
      },
      "id": "gmail-welcome",
      "name": "Gmail: Send Welcome Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [650, -150],
      "credentials": {
        "gmailOAuth2": {
          "id": "GMAIL_CREDENTIAL_ID",
          "name": "Gmail OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html><html><head><meta http-equiv=\"refresh\" content=\"0; url=https://jcsavoy.com/thank-you.html\"><script type=\"text/javascript\">window.location.href = \"https://jcsavoy.com/thank-you.html\";</script></head><body><p>Welcome to the family! Redirecting you to your thank you page (where your book is waiting)...</p></body></html>",
        "options": {}
      },
      "id": "respond-subscribe",
      "name": "Redirect to Thank You",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [650, 50]
    }
  ],
  "connections": {
    "Webhook: Subscribe": {
      "main": [[{ "node": "Honeypot Check", "type": "main", "index": 0 }]]
    },
    "Honeypot Check": {
      "main": [
        [{ "node": "Google Sheets: Add Subscriber", "type": "main", "index": 0 }],
        [{ "node": "Redirect to Thank You", "type": "main", "index": 0 }]
      ]
    },
    "Google Sheets: Add Subscriber": {
      "main": [
        [
          { "node": "Gmail: Send Welcome Email", "type": "main", "index": 0 },
          { "node": "Redirect to Thank You", "type": "main", "index": 0 }
        ]
      ]
    },
    "Webhook: Unsubscribe (MailerLite)": {
      "main": [[{ "node": "Extract Email", "type": "main", "index": 0 }]]
    },
    "Extract Email": {
      "main": [[{ "node": "Google Sheets: Mark Unsubscribed", "type": "main", "index": 0 }]]
    },
    "Google Sheets: Mark Unsubscribed": {
      "main": [[{ "node": "Respond OK", "type": "main", "index": 0 }]]
    }
  }
}
