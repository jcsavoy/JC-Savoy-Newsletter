{
  "name": "JC Savoy Subscriber Management",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "subscribe",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-subscribe",
      "name": "Webhook: Subscribe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "18KYRnngYNcLaCpivRS5dXPm9Ryk7pngfvz5PoEhA44E",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Subscribers",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "manual",
          "value": {
            "Subscriber email": "={{ $json.body.email }}",
            "First Name": "={{ $json.body.first_name }}",
            "Location": "={{ $json.body.location || \"Website\" }}",
            "Date joined": "={{ $now.format(\"yyyy-MM-dd\") }}"
          }
        },
        "options": {}
      },
      "id": "gsheets-subscribe",
      "name": "Google Sheets: Add Subscriber",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [250, 0]
    },
    {
      "parameters": {
        "path": "unsubscribe",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-unsubscribe",
      "name": "Webhook: Unsubscribe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 200]
    },
    {
      "parameters": {
        "operation": "delete",
        "documentId": {
          "__rl": true,
          "value": "18KYRnngYNcLaCpivRS5dXPm9Ryk7pngfvz5PoEhA44E",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Subscribers",
          "mode": "name"
        },
        "filters": {
          "conditions": [
            {
              "leftHandSide": "Subscriber email",
              "operator": "equal",
              "rightHandSide": "={{ $json.query.email }}"
            }
          ]
        },
        "options": {}
      },
      "id": "gsheets-unsubscribe",
      "name": "Google Sheets: Remove Subscriber",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [250, 200]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "={{ $node[\"gsheets-subscribe\"].json[\"Subscriber email\"] }}",
        "subject": "Welcome to the JC Savoy Family! (And your free book 📖)",
        "text": "=Hi {{ $node[\"gsheets-subscribe\"].json[\"First Name\"] }},\n\nSo glad you're here! As promised, here is your free copy of [Book Title] via BookFunnel: [INSERT_BOOKFUNNEL_LINK_HERE]\n\nHappy reading!\n\nJC Savoy",
        "appendAttribution": false
      },
      "id": "gmail-welcome",
      "name": "Gmail: Send Welcome Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [500, -100],
      "credentials": {
        "gmailOAuth2": {
          "id": "GMAIL_CREDENTIAL_ID",
          "name": "Gmail OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html><html><head><meta http-equiv=\"refresh\" content=\"0; url=https://jcsavoy.com/thank-you.html\"><script type=\"text/javascript\">window.location.href = \"https://jcsavoy.com/thank-you.html\";</script></head><body><p>Welcome to the family! Redirecting you to your thank you page (where your book is waiting)...</p></body></html>",
        "options": {}
      },
      "id": "respond-subscribe",
      "name": "Redirect to Thank You",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [750, 0]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html><html><head><meta http-equiv=\"refresh\" content=\"0; url=https://jcsavoy.com/unsubscribed.html\"><script type=\"text/javascript\">window.location.href = \"https://jcsavoy.com/unsubscribed.html\";</script></head><body><p>Redirecting...</p></body></html>",
        "options": {}
      },
      "id": "respond-unsubscribe",
      "name": "Redirect to Unsubscribed",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [500, 200]
    }
  ],
  "connections": {
    "Webhook: Subscribe": {
      "main": [[{ "node": "Google Sheets: Add Subscriber", "type": "main", "index": 0 }]]
    },
    "Google Sheets: Add Subscriber": {
      "main": [
        [{ "node": "Gmail: Send Welcome Email", "type": "main", "index": 0 }],
        [{ "node": "Redirect to Thank You", "type": "main", "index": 0 }]
      ]
    },
    "Webhook: Unsubscribe": {
      "main": [[{ "node": "Google Sheets: Remove Subscriber", "type": "main", "index": 0 }]]
    },
    "Google Sheets: Remove Subscriber": {
      "main": [[{ "node": "Redirect to Unsubscribed", "type": "main", "index": 0 }]]
    }
  }
}
