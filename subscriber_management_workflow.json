{
  "name": "JC Savoy Subscriber Management",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "subscribe",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-subscribe",
      "name": "Webhook: Subscribe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.body.website_url }}",
              "operation": "isEmpty"
            }
          ]
        }
      },
      "id": "if-honeypot",
      "name": "Honeypot Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [200, 0]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "18KYRnngYNcLaCpivRS5dXPm9Ryk7pngfvz5PoEhA44E",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Subscribers",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "manual",
          "value": {
            "Subscriber email": "={{ $json.body.email }}",
            "First Name": "={{ $json.body.first_name }}",
            "Location": "={{ $json.body.location || \"Website\" }}",
            "Date joined": "={{ $now.format(\"yyyy-MM-dd\") }}"
          }
        },
        "options": {}
      },
      "id": "gsheets-subscribe",
      "name": "Google Sheets: Add Subscriber",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [400, -100]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html><html><head><meta http-equiv=\"refresh\" content=\"0; url=https://jcsavoy.com/thank-you.html\"><script type=\"text/javascript\">window.location.href = \"https://jcsavoy.com/thank-you.html\";</script></head><body><p>Welcome to the family! Redirecting...</p></body></html>",
        "options": {}
      },
      "id": "respond-subscribe",
      "name": "Redirect to Thank You",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [600, 0]
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "unsubscribe",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-unsubscribe",
      "name": "Webhook: Unsubscribe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "18KYRnngYNcLaCpivRS5dXPm9Ryk7pngfvz5PoEhA44E",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Subscribers",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Subscriber email": "={{ $json.query.email }}",
            "Unsubscribed": 1
          },
          "matchingColumns": ["Subscriber email"]
        },
        "options": {}
      },
      "id": "gsheets-unsubscribe",
      "name": "Google Sheets: Mark Unsubscribed",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html><html><head><meta http-equiv=\"refresh\" content=\"0; url=https://jcsavoy.com/unsubscribed.html\"><script type=\"text/javascript\">window.location.href = \"https://jcsavoy.com/unsubscribed.html\";</script></head><body><p>Redirecting...</p></body></html>",
        "options": {}
      },
      "id": "respond-unsubscribe",
      "name": "Redirect to Unsubscribed",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Webhook: Subscribe": {
      "main": [[{ "node": "Honeypot Check", "type": "main", "index": 0 }]]
    },
    "Honeypot Check": {
      "main": [
        [{ "node": "Google Sheets: Add Subscriber", "type": "main", "index": 0 }],
        [{ "node": "Redirect to Thank You", "type": "main", "index": 0 }]
      ]
    },
    "Google Sheets: Add Subscriber": {
      "main": [[{ "node": "Redirect to Thank You", "type": "main", "index": 0 }]]
    },
    "Webhook: Unsubscribe": {
      "main": [[{ "node": "Google Sheets: Remove Subscriber", "type": "main", "index": 0 }]]
    },
    "Google Sheets: Remove Subscriber": {
      "main": [[{ "node": "Redirect to Unsubscribed", "type": "main", "index": 0 }]]
    }
  }
}
